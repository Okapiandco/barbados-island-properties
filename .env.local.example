# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Currency Exchange (optional - can use fixed rates)
NEXT_PUBLIC_FX_MODE=manual
NEXT_PUBLIC_USD_TO_GBP=0.79
NEXT_PUBLIC_USD_TO_CAD=1.36

# Admin CSV Import (basic protection)
ADMIN_IMPORT_TOKEN=your_secret_import_token

# Email Settings
GENERIC_ENQUIRIES_EMAIL=info@barbadosislandproperties.com
OFFICE_WHATSAPP=+1-246-XXXXXXX
